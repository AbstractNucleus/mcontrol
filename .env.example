# mcontrol. Copy to .env and fill in.

# Supabase project. Service-role key is server-side only; never expose it
# to the browser.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Absolute path on the host where Minecraft server directories live.
# mcontrol creates, mounts, and manages directories under this path.
SERVER_BASE_PATH=/srv/minecraft

# Host IP the panel HTTP port (8003) binds to. Leave unset for local dev
# (defaults to 127.0.0.1). In production, set to the interface you want
# your reverse proxy to reach the container on.
# HOST_BIND_IP=127.0.0.1
